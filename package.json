{
    "name": "sparta-api",
    "version": "1.0.0",
    "private": true,
    "description": "Sparta API (Node.js + TypeScript) with PostgreSQL",
    "main": "dist/index.js",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "postinstall": "npx puppeteer browsers install chrome",
        "copy:templates": "node -e \"const fs=require('fs');fs.mkdirSync('dist/templates',{recursive:true});fs.cpSync('src/templates','dist/templates',{recursive:true});\"",
        "copy:images": "node -e \"const fs=require('fs');fs.mkdirSync('dist/image',{recursive:true});if(fs.existsSync('src/image')){fs.cpSync('src/image','dist/image',{recursive:true});}\"",
        "build": "tsc -p tsconfig.json && npm run copy:templates && npm run copy:images",
        "start": "node dist/index.js",
        "typecheck": "tsc --noEmit -p tsconfig.json"
    },
    "dependencies": {
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.21.2",
        "googleapis": "^171.4.0",
        "multer": "^1.4.5-lts.2",
        "nunjucks": "^3.2.4",
        "pdf-lib": "^1.17.1",
        "pdfkit": "^0.17.2",
        "pg": "^8.16.3",
        "puppeteer": "^24.6.1",
        "sharp": "^0.34.5",
        "zod": "^3.24.1"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/multer": "^1.4.12",
        "@types/node": "^22.18.6",
        "@types/nunjucks": "^3.2.6",
        "@types/pdfkit": "^0.17.2",
        "@types/pg": "^8.11.10",
        "tsx": "^4.20.5",
        "typescript": "^5.9.2"
    }
}
