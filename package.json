{
    "name": "sparta-api",
    "version": "1.0.1",
    "private": true,
    "description": "Sparta API (Node.js + TypeScript) with PostgreSQL - FORCE REBUILD",
    "main": "dist/index.js",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "postinstall": "npx puppeteer browsers install chrome",
        "copy:templates": "node -e \"const fs=require('fs');fs.mkdirSync('dist/templates',{recursive:true});fs.cpSync('src/templates','dist/templates',{recursive:true});\"",
        "copy:images": "node -e \"const fs=require('fs');fs.mkdirSync('dist/image',{recursive:true});if(fs.existsSync('src/image')){fs.cpSync('src/image','dist/image',{recursive:true});}\"",
        "build": "tsc -p tsconfig.json && npm run copy:templates && npm run copy:images",
        "start": "node dist/index.js",
        "backup:drive": "tsx src/scripts/backup-database-to-drive.ts",
        "backup:drive:prod": "node dist/scripts/backup-database-to-drive.js",
        "repair:denda:first-st": "tsx src/scripts/repair-first-serah-terima-penalty.ts",
        "test:denda": "tsx --test src/modules/denda/denda-keterlambatan.test.ts",
        "test:opname-financial": "tsx --test src/modules/opname-final/opname-final.financial.test.ts",
        "test:opname-schema": "tsx --test src/modules/opname/opname.schema.test.ts",
        "backfill:opname-financial": "tsx src/scripts/backfill-opname-final-financials.ts",
        "regenerate:il-pdfs": "tsx src/scripts/regenerate-instruksi-lapangan-pdfs.ts",
        "correct:serah-terima-date": "tsx src/scripts/correct-serah-terima-date.ts",
        "typecheck": "tsc --noEmit -p tsconfig.json"
    },
    "dependencies": {
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.21.2",
        "googleapis": "^171.4.0",
        "multer": "^1.4.5-lts.2",
        "nunjucks": "^3.2.4",
        "pdf-lib": "^1.17.1",
        "pdf-parse": "^2.4.5",
        "pdfkit": "^0.17.2",
        "pg": "^8.16.3",
        "puppeteer": "^24.6.1",
        "sharp": "^0.34.5",
        "xlsx": "^0.18.5",
        "zod": "^3.24.1"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/multer": "^1.4.12",
        "@types/node": "^22.18.6",
        "@types/nunjucks": "^3.2.6",
        "@types/pdfkit": "^0.17.2",
        "@types/pg": "^8.11.10",
        "tsx": "^4.20.5",
        "typescript": "^5.9.2"
    }
}
