<!doctype html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <style>
    @page {
      size: A4;
      margin: 24mm 20mm;
    }

    body {
      font-family: Arial, sans-serif;
      color: #1f1f1f;
      font-size: 13px;
      line-height: 1.45;
      margin: 0;
    }

    .top-bar {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 20px;
    }

    .brand-group {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .logo-alfamart {
      width: 140px;
      height: auto;
    }

    .logo-building {
      width: 46px;
      height: auto;
    }

    .header-location {
      font-size: 12px;
      text-transform: uppercase;
    }

    .title {
      text-align: center;
      font-size: 26px;
      font-weight: 700;
      letter-spacing: 0.4px;
      margin: 8px 0 22px;
      text-decoration: underline;
    }

    .lead {
      margin: 0 0 10px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin: 10px 0 16px;
      font-size: 12.5px;
    }

    td {
      border: 1px solid #3a3a3a;
      padding: 8px 10px;
      vertical-align: top;
    }

    td.label {
      width: 42%;
      background: #f4f4f4;
      font-weight: 600;
      color: #6a6a6a;
    }

    .closing {
      margin-top: 10px;
    }

    .signature-wrapper {
      margin-top: 48px;
      display: flex;
      justify-content: space-between;
      gap: 30px;
    }

    .signature-block {
      width: 48%;
      text-align: center;
      font-size: 12px;
    }

    .signature-title {
      font-weight: 700;
      margin-top: 2px;
    }

    .timestamp {
      margin-top: 12px;
      font-size: 11px;
      color: #333;
    }

    .signer {
      margin-top: 46px;
      font-weight: 700;
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <div class="top-bar">
    <div class="brand-group">
      {% if logo_alfamart %}
      <img class="logo-alfamart" src="{{ logo_alfamart }}" alt="Alfamart" />
      {% endif %}
      {% if logo_building %}
      <img class="logo-building" src="{{ logo_building }}" alt="Building" />
      {% endif %}
    </div>
    <div class="header-location">{{ cabang_label }}, {{ tanggal_surat }}</div>
  </div>

  <h1 class="title">FORMULIR PERMINTAAN PERPANJANGAN SURAT PERINTAH KERJA (SPK)</h1>

  <p class="lead">Dengan hormat,</p>
  <p class="lead">Bersama ini kami sampaikan detail pengajuan perpanjangan Surat Perintah Kerja (SPK) sebagai berikut:</p>

  <table>
    <tr>
      <td class="label">Nomor SPK</td>
      <td>{{ nomor_spk }}</td>
    </tr>
    <tr>
      <td class="label">Tanggal SPK Akhir</td>
      <td>{{ tanggal_spk_akhir }}</td>
    </tr>
    <tr>
      <td class="label">Pertambahan Hari</td>
      <td>{{ pertambahan_hari }}</td>
    </tr>
    <tr>
      <td class="label">Tanggal SPK Akhir (Setelah Perpanjangan)</td>
      <td>{{ tanggal_spk_akhir_setelah_perpanjangan }}</td>
    </tr>
    <tr>
      <td class="label">Alasan Pertambahan</td>
      <td>{{ alasan_perpanjangan }}</td>
    </tr>
  </table>

  <p class="closing">Demikian formulir permintaan ini kami sampaikan. Atas perhatian dan kerja samanya kami ucapkan terima kasih.</p>

  <div class="signature-wrapper">
    <div class="signature-block">
      <div>Dibuat oleh,</div>
      <div class="signature-title">Branch Building &amp; Maintenance Manager</div>
      <div class="timestamp">Dibuat pada: {{ dibuat_pada }}</div>
      <div class="signer">{{ dibuat_oleh }}</div>
    </div>
    <div class="signature-block">
      <div>Disetujui oleh,</div>
      <div class="signature-title">Branch Manager</div>
      <div class="timestamp">Disetujui pada: {{ disetujui_pada }}</div>
      <div class="signer">{{ disetujui_oleh }}</div>
    </div>
  </div>
</body>
</html>
