<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8" />
    <title>Rekapitulasi RAB</title>
    <style>
        @page {
            size: A4;
            margin: 2.5cm 2cm;
        }

        body {
            font-family: Arial, sans-serif;
            color: #333;
            font-size: 10px;
        }

        .watermark {
            position: fixed;
            top: 50%;
            left: 50%;
            width: 240px;
            transform: translate(-50%, -50%);
            opacity: 0.10;
            z-index: -1;
        }

        .header-company p { margin: 0; font-size: 12px; font-weight: bold; }
        .header-title { text-align: center; margin: 20px 0; }
        .header-title h1 { font-size: 18px; margin: 0; text-decoration: underline; }
        .section-info table { width: 100%; border-collapse: collapse; }
        .section-info td { padding: 2px 0; }

        .price-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 9px;
            margin-top: 10px;
        }

        .price-table th, .price-table td {
            border: 1px solid #333;
            padding: 4px;
            text-align: center;
        }

        .price-table th { background-color: #e0ffff; font-weight: bold; }
        .text-left { text-align: left; }
        .text-right { text-align: right; }

        .grand-total-table {
            margin-top: 20px;
            width: 50%;
            float: right;
            border: none;
            font-size: 10px;
        }

        .grand-total-table td {
            border: 1px solid #ddd;
            padding: 4px;
            text-align: right;
            font-weight: bold;
        }

        .grand-total-table td:first-child { border: none; }
        .total-amount-cell { background-color: #e0ffff; }
        {{ sparta_pdf_css() | safe }}
    </style>
</head>
<body>
    {% if watermark_logo_path %}
    <img src="{{ watermark_logo_path }}" class="watermark" alt="watermark" />
    {% endif %}

    {{ sparta_header("Rekapitulasi Instruksi Lapangan", nama_pt ~ " - Cabang " ~ data.Cabang) | safe }}

    <div class="section-title">Informasi Rekapitulasi</div>
    <div class="section-info">
        <table class="info-table">
            <tr><td class="label">Nomor ULOK</td><td>: {{ data.NomorUlok }}</td><td class="label">Tanggal Pengajuan</td><td>: {{ tanggal_pengajuan }}</td></tr>
            <tr><td class="label">Nama Toko</td><td>: {{ data.nama_toko }}</td><td class="label">Cabang</td><td>: {{ data.Cabang }}</td></tr>
            <tr><td class="label">Proyek</td><td>: {{ data.Proyek }}</td><td class="label">Lingkup Pekerjaan</td><td>: {{ data.LingkupPekerjaan }}</td></tr>
            <tr><td class="label">Alamat Toko</td><td colspan="3">: {{ data.Alamat }}</td></tr>
        </table>
    </div>

    <table class="price-table">
        <thead>
            <tr>
                <th style="width:5%;">NO.</th>
                <th class="text-left" style="width:45%;">KATEGORI PEKERJAAN</th>
                <th style="width:15%;">Total Material</th>
                <th style="width:15%;">Total Upah</th>
                <th style="width:20%;">Total Harga</th>
            </tr>
        </thead>
        <tbody>
            {% for row in category_totals_list %}
            <tr>
                <td>{{ loop.index }}</td>
                <td class="text-left">{{ row.name }}</td>
                <td class="text-right">{{ row.materialFormatted }}</td>
                <td class="text-right">{{ row.upahFormatted }}</td>
                <td class="text-right"><strong>{{ row.totalFormatted }}</strong></td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <table class="grand-total-table">
        <tbody>
            <tr><td>TOTAL (Rp)</td><td class="total-amount-cell">{{ grand_total_formatted }}</td></tr>
            <tr><td>PEMBULATAN (Rp)</td><td class="total-amount-cell">{{ pembulatan_formatted }}</td></tr>
            <tr><td>PPN 11% (Rp)</td><td class="total-amount-cell">{{ ppn_formatted }}</td></tr>
            <tr><td>GRAND TOTAL (Rp)</td><td class="total-amount-cell">{{ final_total_formatted }}</td></tr>
        </tbody>
    </table>
    <div style="clear:both;"></div>
    <div class="footer">Dokumen ini di-generate otomatis oleh sistem SPARTA Building pada {{ tanggal_pengajuan }}</div>
</body>
</html>
