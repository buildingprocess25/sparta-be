<!doctype html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <style>
    @page { size: A4; margin: 15mm; }
    body { font-family: Arial, sans-serif; font-size: 11px; color: #1f2937; margin: 0; }
    .cover-title { margin-top: 30px; border: 2px solid #dc2626; border-radius: 8px; padding: 22px; }
    .eyebrow { color: #dc2626; font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 1.6px; }
    h1 { margin: 8px 0 8px; font-size: 24px; color: #111827; }
    .subtitle { color: #475569; font-size: 12px; line-height: 1.5; }
    .summary-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin: 18px 0; }
    .summary-card { background: #f8fafc; border: 1px solid #d8dee6; border-radius: 6px; padding: 11px; }
    .summary-label { color: #64748b; font-size: 9px; font-weight: 800; text-transform: uppercase; }
    .summary-value { margin-top: 5px; color: #111827; font-size: 17px; font-weight: 800; }
    table { width: 100%; border-collapse: collapse; margin-top: 16px; }
    th, td { border: 1px solid #cbd5e1; padding: 7px 8px; vertical-align: top; }
    th { background: #eef6ff; font-weight: 800; text-align: center; }
    .center { text-align: center; }
    .num { text-align: right; white-space: nowrap; }
    .scope-name { font-weight: 800; color: #dc2626; }
    .note { margin-top: 18px; padding: 12px; background: #fff7ed; border: 1px solid #fed7aa; color: #9a3412; border-radius: 6px; line-height: 1.45; }
    {{ sparta_pdf_css() | safe }}
  </style>
</head>
<body>
  {{ sparta_header("Berita Acara Serah Terima Gabungan", nomor_ulok ~ " - " ~ (nama_toko or '-')) | safe }}
  <div class="cover-title">
    <div class="eyebrow">Dokumen Serah Terima Terpadu</div>
    <h1>Berita Acara Gabungan ULOK {{ nomor_ulok }}</h1>
    <div class="subtitle">Dokumen ini merangkum seluruh lingkup pekerjaan dalam satu berkas terpadu. Rincian opname untuk masing-masing pekerjaan dilampirkan pada halaman berikutnya untuk mempermudah proses pemeriksaan.</div>
  </div>
  <div class="summary-grid">
    <div class="summary-card"><div class="summary-label">Tanggal ST</div><div class="summary-value">{{ created_at_formatted }}</div></div>
    <div class="summary-card"><div class="summary-label">Total Lingkup</div><div class="summary-value">{{ scope_count }}</div></div>
    <div class="summary-card"><div class="summary-label">Total Item</div><div class="summary-value">{{ total_items }}</div></div>
  </div>
  <table>
    <thead>
      <tr>
        <th style="width:32px">No</th>
        <th>Lingkup</th>
        <th>Kode Toko</th>
        <th>Kontraktor</th>
        <th style="width:70px">Item</th>
        <th style="width:110px">Nilai Opname</th>
      </tr>
    </thead>
    <tbody>
      {% for scope in scopes %}
      <tr>
        <td class="center">{{ loop.index }}</td>
        <td class="scope-name">{{ scope.lingkup_pekerjaan or '-' }}</td>
        <td>{{ scope.kode_toko or '-' }}</td>
        <td>{{ scope.nama_kontraktor or '-' }}</td>
        <td class="center">{{ scope.item_count }}</td>
        <td class="num">{{ scope.nilai_opname_formatted }}</td>
      </tr>
      {% endfor %}
    </tbody>
    <tfoot>
      <tr>
        <td colspan="4" class="num"><strong>Total</strong></td>
        <td class="center"><strong>{{ total_items }}</strong></td>
        <td class="num"><strong>{{ total_nilai_formatted }}</strong></td>
      </tr>
    </tfoot>
  </table>
  <div class="note"><strong>Petunjuk Lampiran:</strong> Rincian pekerjaan disusun secara berurutan mulai dari lingkup {{ scope_order }}. Setiap lampiran memiliki halamannya tersendiri.</div>
</body>
</html>
