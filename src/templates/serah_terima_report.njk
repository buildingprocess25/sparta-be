<!doctype html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <style>
    @page {
      size: A4;
      margin: 18mm 14mm;
    }

    body {
      font-family: Arial, sans-serif;
      font-size: 11px;
      color: #1f2937;
      margin: 0;
      position: relative;
    }

    .watermark {
      position: fixed;
      top: 50%;
      left: 50%;
      width: 240px;
      transform: translate(-50%, -50%);
      opacity: 0.08;
      z-index: 0;
      pointer-events: none;
    }

    .content {
      position: relative;
      z-index: 1;
    }

    .header {
      text-align: center;
      margin-bottom: 16px;
      border-bottom: 3px double #e30613;
      padding-bottom: 10px;
    }

    .title {
      margin: 0;
      font-size: 22px;
      font-weight: 700;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      color: #e30613;
    }

    .subtitle {
      margin: 4px 0 0;
      color: #4b5563;
      font-size: 12px;
    }

    .meta {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 14px;
    }

    .meta td {
      border: 1px solid #c7cbd1;
      padding: 6px 8px;
      vertical-align: top;
    }

    .meta .label {
      width: 170px;
      font-weight: 600;
      background: #f6f8fb;
    }

    .section-title {
      font-size: 13px;
      font-weight: 700;
      margin: 14px 0 6px;
      color: #e30613;
      text-transform: uppercase;
      border-bottom: 1px solid #e30613;
      padding-bottom: 4px;
    }

    .items {
      width: 100%;
      border-collapse: collapse;
      margin-top: 8px;
    }

    .items th,
    .items td {
      border: 1px solid #aeb4bc;
      padding: 5px 6px;
      vertical-align: top;
      font-size: 10px;
    }

    .items th {
      background: #e30613;
      color: #ffffff;
      font-weight: 600;
      text-transform: uppercase;
    }

    .num {
      text-align: right;
      white-space: nowrap;
    }

    .center {
      text-align: center;
    }

    .summary {
      margin-top: 12px;
      width: 100%;
      border-collapse: collapse;
    }

    .summary td {
      border: 1px solid #c7cbd1;
      padding: 6px 8px;
    }

    .summary .label {
      width: 220px;
      background: #f6f8fb;
      font-weight: 600;
    }

    .footer {
      margin-top: 16px;
      font-size: 10px;
      color: #6b7280;
      text-align: right;
    }
  </style>
</head>
<body>
  {% if watermark_logo_path %}
  <img src="{{ watermark_logo_path }}" class="watermark" alt="watermark" />
  {% endif %}

  <div class="content">
  <div class="header">
    <h1 class="title">Berita Acara Serah Terima</h1>
    <p class="subtitle">Berdasarkan Data Opname Final</p>
  </div>

  <table class="meta">
    <tr>
      <td class="label">Nomor ULOK</td>
      <td>{{ toko.nomor_ulok or '-' }}</td>
      <td class="label">Tanggal Dokumen</td>
      <td>{{ generated_at }}</td>
    </tr>
    <tr>
      <td class="label">Nama Toko</td>
      <td>{{ toko.nama_toko or '-' }}</td>
      <td class="label">Kode Toko</td>
      <td>{{ toko.kode_toko or '-' }}</td>
    </tr>
    <tr>
      <td class="label">Proyek</td>
      <td>{{ toko.proyek or '-' }}</td>
      <td class="label">Cabang</td>
      <td>{{ toko.cabang or '-' }}</td>
    </tr>
    <tr>
      <td class="label">Alamat</td>
      <td colspan="3">{{ toko.alamat or '-' }}</td>
    </tr>
    <tr>
      <td class="label">Nama Kontraktor</td>
      <td>{{ toko.nama_kontraktor or '-' }}</td>
      <td class="label">Lingkup Pekerjaan</td>
      <td>{{ toko.lingkup_pekerjaan or '-' }}</td>
    </tr>
  </table>

  <div class="section-title">Daftar Pekerjaan</div>

  <table class="items">
    <thead>
      <tr>
        <th style="width:28px">No</th>
        <th>Kategori</th>
        <th>Jenis Pekerjaan</th>
        <th class="center" style="width:90px">Desain</th>
        <th class="center" style="width:90px">Kualitas</th>
        <th class="center" style="width:90px">Spesifikasi</th>
      </tr>
    </thead>
    <tbody>
      {% for item in items %}
      <tr>
        <td class="center">{{ loop.index }}</td>
        <td>{{ item.kategori_pekerjaan or '-' }}</td>
        <td>{{ item.jenis_pekerjaan or '-' }}</td>
        <td class="center">{{ item.desain or '-' }}</td>
        <td class="center">{{ item.kualitas or '-' }}</td>
        <td class="center">{{ item.spesifikasi or '-' }}</td>
      </tr>
      {% endfor %}
      {% if items.length === 0 %}
      <tr>
        <td colspan="6" class="center">Belum ada item opname.</td>
      </tr>
      {% endif %}
    </tbody>
  </table>

  <table class="summary">
    <tr>
      <td class="label">Grand Total RAB</td>
      <td class="num">{{ grand_total_rab_formatted }}</td>
    </tr>
    <tr>
      <td class="label">Grand Total Opname</td>
      <td class="num">{{ grand_total_opname_formatted }}</td>
    </tr>
    <tr>
      <td class="label">Selisih Total</td>
      <td class="num">{{ selisih_total_formatted }}</td>
    </tr>
  </table>

  <div class="footer">
    Digenerate otomatis oleh sistem SPARTA pada {{ generated_at }}
  </div>
  </div>
</body>
</html>
