<!doctype html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <style>
    @page {
      size: A4;
      margin: 18mm 14mm;
    }

    body {
      font-family: Arial, sans-serif;
      font-size: 11px;
      color: #1f2937;
      margin: 0;
      position: relative;
    }

    .watermark {
      position: fixed;
      top: 50%;
      left: 50%;
      width: 240px;
      transform: translate(-50%, -50%);
      opacity: 0.08;
      z-index: 0;
      pointer-events: none;
    }

    .content {
      position: relative;
      z-index: 1;
    }

    .header {
      text-align: center;
      margin-bottom: 16px;
      border-bottom: 3px double #e30613;
      padding-bottom: 10px;
    }

    .title {
      margin: 0;
      font-size: 22px;
      font-weight: 700;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      color: #e30613;
    }

    .subtitle {
      margin: 4px 0 0;
      color: #4b5563;
      font-size: 12px;
    }

    .meta {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 14px;
    }

    .meta td {
      border: 1px solid #c7cbd1;
      padding: 6px 8px;
      vertical-align: top;
    }

    .meta .label {
      width: 170px;
      font-weight: 600;
      background: #f6f8fb;
    }

    .section-title {
      font-size: 13px;
      font-weight: 700;
      margin: 14px 0 6px;
      color: #e30613;
      text-transform: uppercase;
      border-bottom: 1px solid #e30613;
      padding-bottom: 4px;
    }

    .category-header {
      font-size: 12px;
      font-weight: 700;
      margin-top: 12px;
      padding: 6px 0 4px;
      border-bottom: 1px solid #e30613;
      text-transform: uppercase;
      color: #b91c1c;
    }

    .items {
      width: 100%;
      border-collapse: collapse;
      margin-top: 8px;
    }

    .items th,
    .items td {
      border: 1px solid #aeb4bc;
      padding: 5px 6px;
      vertical-align: top;
      font-size: 10px;
    }

    .items th {
      background: #eef6ff;
      color: #111827;
      font-weight: 600;
      text-transform: uppercase;
    }

    .assessment-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px;
      margin: 10px 0 16px;
    }

    .assessment-card {
      border: 1px solid #cbd5e1;
      border-radius: 6px;
      padding: 9px 10px;
      background: #f8fafc;
    }

    .assessment-label {
      font-size: 9px;
      font-weight: 700;
      color: #64748b;
      text-transform: uppercase;
      margin-bottom: 5px;
    }

    .assessment-value {
      font-size: 16px;
      font-weight: 800;
      color: #111827;
      margin-bottom: 2px;
    }

    .assessment-detail {
      font-size: 9px;
      color: #475569;
    }

    .num {
      text-align: right;
      white-space: nowrap;
    }

    .center {
      text-align: center;
    }

    .item-photo {
      width: 76px;
      height: 58px;
      object-fit: cover;
      border: 1px solid #cbd5e1;
      border-radius: 4px;
      background: #f8fafc;
      display: block;
      margin: 0 auto;
    }

    .photo-placeholder {
      font-size: 8px;
      color: #94a3b8;
      line-height: 1.25;
    }

    .summary {
      margin-top: 12px;
      width: 100%;
      border-collapse: collapse;
    }

    .summary td {
      border: 1px solid #c7cbd1;
      padding: 6px 8px;
    }

    .summary .label {
      width: 220px;
      background: #f6f8fb;
      font-weight: 600;
    }

    .footer {
      margin-top: 16px;
      font-size: 10px;
      color: #6b7280;
      text-align: right;
    }
    {{ sparta_pdf_css() | safe }}
  </style>
</head>
<body>
  {% if watermark_logo_path %}
  <img src="{{ watermark_logo_path }}" class="watermark" alt="watermark" />
  {% endif %}

  <div class="content">
  {{ sparta_header("Berita Acara Serah Terima", toko.nomor_ulok ~ " - " ~ (toko.nama_toko or '-')) | safe }}

  {% if unified_part_index %}
  <div style="margin-bottom: 25px; border-bottom: 1px solid #aeb4bc; padding-bottom: 15px;">
    <div style="font-size: 11px; font-weight: bold; color: #e30613; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px;">Bagian {{ unified_part_index }} dari {{ unified_part_total }}</div>
    <div style="font-size: 18px; font-weight: bold; color: #000000; text-transform: uppercase; margin-bottom: 6px;">Lampiran Pekerjaan: {{ toko.lingkup_pekerjaan or '-' }}</div>
    <div style="font-size: 12px; color: #475569;">Berikut adalah rincian penilaian untuk lingkup pekerjaan ini.</div>
  </div>
  {% endif %}

  <div class="section-title">Informasi Serah Terima</div>
  <table class="meta">
    <tr>
      <td class="label">Nomor ULOK</td>
      <td>{{ toko.nomor_ulok or '-' }}</td>
      <td class="label">Tanggal Serah Terima</td>
      <td>{{ created_at_formatted }}</td>
    </tr>
    <tr>
      <td class="label">Nama Toko</td>
      <td>{{ toko.nama_toko or '-' }}</td>
      <td class="label">Kode Toko</td>
      <td>{{ toko.kode_toko or '-' }}</td>
    </tr>
    <tr>
      <td class="label">Proyek</td>
      <td>{{ toko.proyek or '-' }}</td>
      <td class="label">Cabang</td>
      <td>{{ toko.cabang or '-' }}</td>
    </tr>
    <tr>
      <td class="label">Alamat</td>
      <td colspan="3">{{ toko.alamat or '-' }}</td>
    </tr>
    <tr>
      <td class="label">Nama Kontraktor</td>
      <td>{{ toko.nama_kontraktor or '-' }}</td>
      <td class="label">Lingkup Pekerjaan</td>
      <td>{{ toko.lingkup_pekerjaan or '-' }}</td>
    </tr>
  </table>

  <div class="section-title">Daftar Pekerjaan</div>

  {% for group in grouped_items_list %}
  <div class="category-header">{{ loop.index }}. {{ group.category }}</div>
  <table class="items">
    <thead>
      <tr>
        <th style="width:28px">No</th>
        <th>Jenis Pekerjaan</th>
        <th class="center" style="width:90px">Desain</th>
        <th class="center" style="width:90px">Kualitas</th>
        <th class="center" style="width:90px">Spesifikasi</th>
        <th class="center" style="width:90px">Dokumentasi</th>
      </tr>
    </thead>
    <tbody>
      {% for item in group.items %}
      <tr>
        <td class="center">{{ loop.index }}</td>
        <td>{{ item.jenis_pekerjaan or '-' }}</td>
        <td class="center">{{ item.desain or '-' }}</td>
        <td class="center">{{ item.kualitas or '-' }}</td>
        <td class="center">{{ item.spesifikasi or '-' }}</td>
        <td class="center">
          {% if item.foto_data_url %}
          <img class="item-photo" src="{{ item.foto_data_url }}" alt="Foto serah terima {{ loop.index }}" />
          {% else %}
          <span class="photo-placeholder">Foto tidak tersedia</span>
          {% endif %}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% endfor %}
  {% if grouped_items_list.length === 0 %}
  <table class="items">
    <tr>
      <td colspan="6" class="center">Belum ada item opname.</td>
    </tr>
  </table>
  {% endif %}

  <div class="section-title">Rekap Penilaian Serah Terima</div>
  <div class="assessment-grid">
    {% for item in assessment_summary %}
    <div class="assessment-card">
      <div class="assessment-label">{{ item.label }}</div>
      <div class="assessment-value">{{ item.value }}</div>
      <div class="assessment-detail">{{ item.detail }}</div>
    </div>
    {% endfor %}
  </div>

  <div class="footer">
    Dokumen ini di-generate otomatis oleh sistem SPARTA Building pada {{ generated_at }}
  </div>
  </div>
</body>
</html>
