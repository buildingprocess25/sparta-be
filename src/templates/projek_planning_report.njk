<!doctype html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <title>Laporan Project Planning</title>
  <style>
    @page {
      size: A4;
      margin: 15mm 15mm 20mm 15mm;
    }

    body {
      font-family: Arial, sans-serif;
      font-size: 10px;
      color: #333;
      margin: 0;
      padding: 0;
    }

    .header-main {
      background-color: #dc2626;
      color: #ffffff;
      padding: 14px 20px;
      display: flex;
      align-items: center;
      margin-bottom: 20px;
      border-radius: 4px;
    }

    .header-alfamart-logo {
      height: 38px;
      margin-right: 14px;
      padding-right: 14px;
      border-right: 2px solid rgba(255,255,255,0.35);
    }

    .header-sparta-logo {
      height: 32px;
      margin-right: 10px;
    }

    .header-title {
      font-size: 22px;
      font-weight: bold;
      margin: 0;
      letter-spacing: 2px;
    }

    .header-subtitle {
      font-size: 11px;
      margin: 0;
      opacity: 0.85;
      letter-spacing: 0.5px;
    }

    .section-title {
      font-size: 14px;
      font-weight: bold;
      color: #dc2626;
      border-bottom: 1px solid #dc2626;
      padding-bottom: 4px;
      margin-top: 20px;
      margin-bottom: 10px;
    }

    .info-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 15px;
    }

    .info-table td {
      padding: 4px 0;
      vertical-align: top;
    }

    .info-table .label {
      font-weight: bold;
      color: #555;
      width: 120px;
    }

    .info-table .value {
      color: #111;
      width: 32%;
      padding-right: 18px;
    }

    .info-table a {
      color: #2563eb;
      text-decoration: underline;
    }

    .info-table .full-value {
      color: #111;
      padding-right: 0;
    }

    .data-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 10px;
      margin-bottom: 15px;
    }

    .data-table th, .data-table td {
      border: 1px solid #e5e7eb;
      padding: 6px 8px;
    }

    .data-table th {
      background-color: #fef2f2;
      color: #dc2626;
      text-align: left;
      font-weight: bold;
    }

    .data-table td.label-col {
      width: 40%;
      background-color: #fafafa;
    }

    .approval-table {
      width: 100%;
      margin-top: 30px;
      border-collapse: collapse;
      text-align: center;
      page-break-inside: avoid;
    }

    .approval-box {
      border-top: 4px solid #dc2626;
      background: #f9fafb;
      padding: 10px;
      margin: 0 5px;
      border-radius: 0 0 4px 4px;
      text-align: center;
    }

    .approval-box.bm { border-color: #dc2626; }
    .approval-box.pp1 { border-color: #dc2626; }
    .approval-box.pp2 { border-color: #dc2626; }

    .approval-title {
      font-size: 11px;
      font-weight: bold;
      color: #ffffff;
      background: #dc2626;
      padding: 6px;
      margin: 0 5px;
      border-radius: 4px 4px 0 0;
      text-transform: uppercase;
      text-align: center;
    }

    .approval-name {
      font-weight: bold;
      margin-top: 40px;
      font-size: 11px;
      text-align: center;
    }

    .approval-nik {
      font-size: 9px;
      color: #666;
      text-align: center;
    }

    .approval-date {
      font-size: 9px;
      color: #888;
      margin-top: 4px;
      font-style: italic;
      text-align: center;
      white-space: nowrap;
    }

    .approval-role {
      font-size: 10px;
      color: #555;
      margin-top: 10px;
      border-top: 1px solid #eee;
      padding-top: 5px;
      text-align: center;
    }

    .footer {
      margin-top: 30px;
      font-size: 9px;
      color: #888;
      text-align: center;
      border-top: 1px solid #eee;
      padding-top: 5px;
      padding-bottom: 5px;
    }

    .watermark {
      position: fixed;
      top: 50%;
      left: 50%;
      width: 400px;
      transform: translate(-50%, -50%);
      opacity: 0.05;
      z-index: -1;
      pointer-events: none;
    }
  </style>
</head>
<body>
  {% if watermark_logo_path %}
  <img src="{{ watermark_logo_path }}" class="watermark" alt="watermark" />
  {% endif %}

  <div class="header-main" style="justify-content: space-between;">
    <div style="display: flex; align-items: center;">
      {% if alfamart_logo_path %}
      <img src="{{ alfamart_logo_path }}" class="header-alfamart-logo" alt="Alfamart" />
      {% endif %}
      {% if sparta_logo_path %}
      <img src="{{ sparta_logo_path }}" class="header-sparta-logo" alt="SPARTA" />
      {% endif %}
      <div>
        <h1 class="header-title">SPARTA</h1>
        <p class="header-subtitle">Building</p>
      </div>
    </div>
    <div style="font-size: 14px; font-weight: bold; color: #fff; letter-spacing: 0.5px;">
      FPD (Form Permintaan Desain)
    </div>
  </div>

  <div class="section-title">Informasi Utama</div>
  <table class="info-table">
    <tr>
      <td class="label">Nomor ULOK</td>
      <td class="value">: {{ projek.nomor_ulok }}</td>
      <td class="label">Tanggal Submit</td>
      <td class="value">: {{ created_at_formatted }}</td>
    </tr>
    <tr>
      <td class="label">Nama Toko</td>
      <td class="value">: {{ projek.nama_toko or '-' }}</td>
      <td class="label">Cabang</td>
      <td class="value">: {{ projek.cabang or '-' }}</td>
    </tr>
    <tr>
      <td class="label">Kode Toko</td>
      <td class="value">: {{ projek.kode_toko or '-' }}</td>
      <td class="label">Nama Pengaju</td>
      <td class="value">: {{ projek.nama_pengaju or '-' }}</td>
    </tr>
    <tr>
      <td class="label">Proyek</td>
      <td class="value">: {{ projek.proyek or '-' }}</td>
      <td class="label">Jenis Pengajuan</td>
      <td class="value">: {{ projek.jenis_pengajuan or '-' }}</td>
    </tr>
    <tr>
      <td class="label">Tipe Bangunan</td>
      <td class="value">: {{ 'Ruko (' + projek.jumlah_lantai + ' Lantai)' if projek.is_ruko else 'Non-Ruko' }}</td>
      <td class="label">Kategori Toko</td>
      <td class="value">: {{ '-' if 'DARK STORE' in (projek.jenis_pengajuan or '') else ('B2B' if projek.is_dark_store else 'Reguler') }}</td>
    </tr>
    <tr>
      <td class="label">Head to Head</td>
      <td class="value">: {{ '-' if 'DARK STORE' in (projek.jenis_pengajuan or '') else ('Ya' + (' (' + projek.jarak_head_to_head + ' m)' if projek.jarak_head_to_head else '') if projek.is_head_to_head else 'Tidak') }}</td>
      <td class="label">Seating Area</td>
      <td class="value">: {{ '-' if 'DARK STORE' in (projek.jenis_pengajuan or '') else ('Ya' if projek.is_seating_area else 'Tidak') }}</td>
    </tr>
  </table>

  <div class="section-title">Data Luasan & Dimensi</div>
  <table class="info-table">
    <tr>
      <td class="label">Luas Bangunan</td>
      <td class="value">: {{ projek.luas_bangunan or '-' }}{% if projek.luas_bangunan %} m²{% endif %}</td>
      <td class="label">Luas Area Terbuka</td>
      <td class="value">: {{ projek.luas_area_terbuka or '-' }}{% if projek.luas_area_terbuka %} m²{% endif %}</td>
    </tr>
    <tr>
      <td class="label">Luas Terbangun</td>
      <td class="value">: {{ projek.luas_area_terbangun or '-' }}{% if projek.luas_area_terbangun %} m²{% endif %}</td>
      <td class="label">Luas Gudang</td>
      <td class="value">: {{ projek.luas_gudang or '-' }}{% if projek.luas_gudang %} m²{% endif %}</td>
    </tr>
    <tr>
      <td class="label">Luas Parkir</td>
      <td class="value">: {{ projek.luas_area_parkir or '-' }}{% if projek.luas_area_parkir %} m²{% endif %}</td>
      <td class="label">Luas Sales</td>
      <td class="value">: {{ projek.luas_area_sales or '-' }}{% if projek.luas_area_sales %} m²{% endif %}</td>
    </tr>
    <tr>
      <td class="label">P x L Bangunan</td>
      <td class="value">: {{ (projek.p_bangunan + ' m x ' + projek.l_bangunan + ' m') if projek.p_bangunan and projek.l_bangunan else (projek.pxl_bangunan or '-') }}</td>
      <td class="label">P x L Parkir</td>
      <td class="value">: {{ (projek.p_area_parkir + ' m x ' + projek.l_area_parkir + ' m') if projek.p_area_parkir and projek.l_area_parkir else (projek.pxl_area_parkir or '-') }}</td>
    </tr>
  </table>

  <div class="section-title">Lokasi & Keterangan</div>
  <table class="info-table">
    <tr>
      <td class="label">Google Maps</td>
      <td class="full-value" colspan="3">
        : {% if projek.link_google_maps %}
          <a href="{{ projek.link_google_maps }}">Buka Lokasi</a>
        {% else %}
          -
        {% endif %}
      </td>
    </tr>
    <tr>
      <td class="label">Siteplan</td>
      <td class="full-value" colspan="3">
        : {% if projek.link_siteplan %}
          <a href="{{ projek.link_siteplan }}">Buka Siteplan</a>
        {% else %}
          -
        {% endif %}
      </td>
    </tr>
    {% if projek.alamat_toko %}
    <tr>
      <td class="label">Alamat</td>
      <td class="full-value" colspan="3">: {{ projek.alamat_toko }}</td>
    </tr>
    {% endif %}
  </table>

  <div class="section-title">Fasilitas & Ketentuan</div>
  <table class="data-table">
    <tr>
      <td class="label-col">Jenis Pengajuan Desain</td>
      <td>{{ projek.jenis_pengajuan or '-' }} {{ '(' + projek.jenis_pengajuan_lainnya + ')' if projek.jenis_pengajuan == 'LAINNYA' and projek.jenis_pengajuan_lainnya else '' }}</td>
    </tr>
    {% if projek.sumber_air_bersih %}
    <tr><td class="label-col">Sumber Air Bersih</td><td>{{ projek.sumber_air_bersih }}</td></tr>
    {% endif %}
    {% if projek.drainase_air_kotor %}
    <tr><td class="label-col">Drain Pembuangan Air Kotor</td><td>{{ projek.drainase_air_kotor }}</td></tr>
    {% endif %}
    {% if projek.jumlah_ac %}
    <tr><td class="label-col">AC</td><td>{{ projek.jumlah_ac }} Unit {{ '(' + projek.pk_ac + ' PK)' if projek.pk_ac else '' }}</td></tr>
    {% endif %}
    {% if projek.listrik_va %}
    <tr><td class="label-col">Listrik</td><td>{{ projek.listrik_va }} VA {{ '(' + projek.listrik_phase + ' Phase)' if projek.listrik_phase else '' }}</td></tr>
    {% endif %}

    {% if projek.fasilitas and projek.fasilitas.length > 0 %}
      {% for fas in projek.fasilitas %}
      <tr>
        <td class="label-col">
          {% if fas.jenis_fasilitas == 'LAINNYA' %}
            {{ fas.nama_fasilitas_lainnya }}
          {% else %}
            {% if fas.jenis_fasilitas == 'AIR_BERSIH' %}Sumber Air Bersih (Lama)
            {% elif fas.jenis_fasilitas == 'DRAINASE' %}Drain Pembuangan Air Kotor (Lama)
            {% elif fas.jenis_fasilitas == 'AC' %}AC (Lama)
            {% else %}{{ fas.jenis_fasilitas }}{% endif %}
          {% endif %}
        </td>
        <td>{{ 'Ya' if fas.is_tersedia else 'Tidak' }} {{ '(' + fas.keterangan + ')' if fas.keterangan else '' }}</td>
      </tr>
      {% endfor %}
    {% endif %}
  </table>

  {% if projek.ketentuan and projek.ketentuan.length > 0 %}
  <div class="section-title">Ketentuan Pengelola / Pihak Ketiga</div>
  <table class="data-table">
    {% for ket in projek.ketentuan %}
    <tr><td class="label-col">Ketentuan {{ loop.index }}</td><td>{{ ket.isi_ketentuan }}</td></tr>
    {% endfor %}
  </table>
  {% endif %}

  {% if projek.catatan_design and projek.catatan_design.length > 0 %}
  <div class="section-title">Catatan Desain</div>
  <table class="data-table">
    {% for cat in projek.catatan_design %}
    <tr><td class="label-col">Catatan {{ loop.index }}</td><td>{{ cat.isi_catatan }}</td></tr>
    {% endfor %}
  </table>
  {% endif %}

  <table class="approval-table" style="margin-top: 40px;">
    <tr>

      {# ── [1] DIBUAT — Coordinator (selalu ada nama & tanggal) ── #}
      <td style="width: 25%; vertical-align: top; text-align: center;">
        <div class="approval-title">DIBUAT</div>
        <div class="approval-box bm" style="min-height: 90px;">
          <div style="min-height: 25px;"></div>
          <div class="approval-date">{{ created_at_formatted }}</div>
          <div style="min-height: 25px;"></div>
          <div class="approval-name">{{ projek.email_pembuat.split('@')[0] | upper }}</div>
          <div class="approval-role">Branch Building Coordinator</div>
        </div>
      </td>

      {# ── [2] MENGETAHUI — B&M Manager (nama & tanggal jika sudah approve) ── #}
      <td style="width: 25%; vertical-align: top; text-align: center;">
        <div class="approval-title">MENGETAHUI</div>
        <div class="approval-box pp1" style="min-height: 90px;">
          {% if has_bm_signature %}
            <div style="min-height: 25px;"></div>
            <div class="approval-date">{{ bm_waktu_formatted or '-' }}</div>
            <div style="min-height: 25px;"></div>
            <div class="approval-name">{{ bm_approver_email_final.split('@')[0] | upper }}</div>
          {% else %}
            <div style="min-height: 80px;"></div>
          {% endif %}
          <div class="approval-role">Building &amp; Maintenance Manager</div>
        </div>
      </td>

      {# ── [3] MENGETAHUI — PP Specialist (nama & tanggal jika sudah approve) ── #}
      <td style="width: 25%; vertical-align: top; text-align: center;">
        <div class="approval-title">MENGETAHUI</div>
        <div class="approval-box pp2" style="min-height: 90px;">
          {% if has_pp_specialist_signature %}
            <div style="min-height: 25px;"></div>
            <div class="approval-date">{{ pp2_waktu_formatted or '-' }}</div>
            <div style="min-height: 25px;"></div>
            <div class="approval-name">{{ pp_specialist_approver_email.split('@')[0] | upper }}</div>
          {% else %}
            <div style="min-height: 80px;"></div>
          {% endif %}
          <div class="approval-role">Project Planning &amp; Development Specialist</div>
        </div>
      </td>

      {# ── [4] DISETUJUI — PP Manager (nama & tanggal jika sudah approve) ── #}
      <td style="width: 25%; vertical-align: top; text-align: center;">
        <div class="approval-title">DISETUJUI</div>
        <div class="approval-box bm" style="min-height: 90px;">
          {% if has_pp_manager_signature %}
            <div style="min-height: 25px;"></div>
            <div class="approval-date">{{ pp_manager_waktu_formatted or '-' }}</div>
            <div style="min-height: 25px;"></div>
            <div class="approval-name">{{ projek.pp_manager_approver_email.split('@')[0] | upper }}</div>
          {% else %}
            <div style="min-height: 80px;"></div>
          {% endif %}
          <div class="approval-role">Project Planning &amp; Development Manager</div>
        </div>
      </td>

    </tr>
  </table>


  {% if projek.foto_items and projek.foto_items.length > 0 %}
  <div style="page-break-before: always;"></div>
  
  <div class="header-main" style="margin-bottom: 16px;">
    <table style="width: 100%; border: none; border-collapse: collapse;">
      <tr>
        <td style="width: 15%; border: none; vertical-align: middle;">
          <img src="{{ alfamart_logo_path }}" alt="Alfamart Logo" style="height: 38px;">
        </td>
        <td style="width: 70%; text-align: center; border: none; vertical-align: middle;">
          <div style="font-size: 16px; font-weight: bold; color: #fff; letter-spacing: 1.5px;">LAMPIRAN FOTO DOKUMENTASI</div>
          <div style="font-size: 10px; color: rgba(255,255,255,0.85); margin-top: 2px;">FORM PERMINTAAN DESAIN (FPD)</div>
        </td>
        <td style="width: 15%; text-align: right; border: none; vertical-align: middle;">
          <img src="{{ sparta_logo_path }}" alt="Sparta Logo" style="height: 32px;">
        </td>
      </tr>
    </table>
  </div>

  <div style="margin-top: 20px;">
    {% for foto in projek.foto_items %}
      {% if foto.item_index == 39 %}
        <div style="display:block; width:100%; margin: 18px 0 10px 0; padding: 8px 10px; background:#fee2e2; color:#991b1b; border-left: 5px solid #dc2626; font-size: 13px; font-weight: bold; page-break-inside: avoid;">
          Dokumentasi Head to Head Kompetitor
        </div>
      {% endif %}
      <div style="display: inline-block; width: 48%; border: 1px solid #000; margin-bottom: 15px; margin-right: 1%; vertical-align: top; page-break-inside: avoid;">
        <div style="background-color: #f1f5f9; padding: 5px; font-weight: bold; border-bottom: 1px solid #000; font-size: 11px; text-align: center;">
          {{ foto.item_index }}. {{ foto.label or ('Titik ' + foto.item_index) }}
        </div>
        <div style="padding: 5px; text-align: center; height: 250px; display: flex; align-items: center; justify-content: center; background: #f9f9f9;">
          {% if foto.base64 %}
            <img src="{{ foto.base64 }}" style="max-width: 100%; max-height: 240px; object-fit: contain;" />
          {% else %}
            <span style="color: #999; font-size: 10px; font-style: italic;">Gambar tidak tersedia</span>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
  {% endif %}

  <div class="footer">
    No. Laporan: {{ projek.id }} — Dokumen ini di-generate otomatis oleh sistem SPARTA Building pada {{ generated_at }}
  </div>
</body>
</html>
