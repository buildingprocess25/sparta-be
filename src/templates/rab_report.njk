<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8" />
    <title>RAB</title>
    <style>
        @page {
            size: A4;
            margin: 2.5cm 2cm;
        }

        body {
            font-family: Arial, sans-serif;
            color: #333;
            font-size: 10px;
        }

        .watermark {
            position: fixed;
            top: 50%;
            left: 50%;
            width: 240px;
            transform: translate(-50%, -50%);
            opacity: 0.10;
            z-index: -1;
        }

        .header-company p {
            margin: 0;
            font-size: 12px;
            font-weight: bold;
        }

        .header-title {
            text-align: center;
            margin: 20px 0;
        }

        .header-title h1 {
            font-size: 18px;
            margin: 0;
            text-decoration: underline;
        }

        .section-info table {
            width: 100%;
            font-size: 10px;
            border-collapse: collapse;
        }

        .section-info td {
            padding: 2px 0;
        }

        .price-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 9px;
            margin-top: 10px;
        }

        .price-table th, .price-table td {
            border: 1px solid #333;
            padding: 4px;
            text-align: center;
        }

        .price-table th {
            background-color: #e0ffff;
            font-weight: bold;
        }

        .text-left { text-align: left; }
        .text-right { text-align: right; }

        .category-header {
            font-size: 12px;
            font-weight: bold;
            border-bottom: 1px solid #333;
            padding: 8px 0 4px 0;
            margin-top: 20px;
            margin-bottom: 10px;
        }

        .sub-total-row td {
            font-weight: bold;
            background-color: #f2f2f2;
        }

        .grand-total-table {
            margin-top: 20px;
            width: 50%;
            float: right;
            border: none;
            font-size: 10px;
        }

        .grand-total-table td {
            border: 1px solid #ddd;
            padding: 4px;
            text-align: right;
            font-weight: bold;
        }

        .grand-total-table td:first-child {
            border: none;
        }

        .total-amount-cell { background-color: #e0ffff; }

        .signatures {
            display: table;
            width: 100%;
            margin-top: 30px;
            text-align: center;
            page-break-inside: avoid;
        }

        .signature-box {
            display: table-cell;
            width: 33%;
            vertical-align: top;
        }

        .signatures.batam-two-cols .signature-box {
            width: 50%;
        }

        .signature-content {
            height: 65px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        .approval-details {
            font-size: 9px;
            line-height: 1.4;
            color: #555;
        }

        .signature-line {
            position: absolute;
            bottom: 0;
            left: 10%;
            width: 80%;
            height: 1px;
            background-color: #333;
        }
    </style>
</head>
<body>
    {% if watermark_logo_path %}
    <img src="{{ watermark_logo_path }}" class="watermark" alt="watermark" />
    {% endif %}

    <div class="header-company">
        <p>{{ nama_pt }}</p>
        <p>Cabang {{ data.Cabang }}</p>
    </div>

    <div class="header-title">
        <h1>RENCANA ANGGARAN BIAYA</h1>
    </div>

    <div class="section-info">
        <table>
            <tr><td style="width:30%;">NOMOR ULOK</td><td style="width:2%;">:</td><td>{{ data.NomorUlok }}</td></tr>
            <tr><td>NAMA TOKO</td><td>:</td><td>{{ data.nama_toko }}</td></tr>
            <tr><td>PROYEK</td><td>:</td><td>{{ data.Proyek }}</td></tr>
            <tr><td>ALAMAT TOKO</td><td>:</td><td>{{ data.Alamat }}</td></tr>
            <tr><td>LINGKUP PEKERJAAN</td><td>:</td><td>{{ data.LingkupPekerjaan }}</td></tr>
            <tr><td>DURASI PEKERJAAN</td><td>:</td><td>{{ data.DurasiPekerjaan }}</td></tr>
            <tr><td>KATEGORI LOKASI</td><td>:</td><td>{{ data.KategoriLokasi }}</td></tr>
            <tr><td>LUAS AREA PARKIR</td><td>:</td><td>{{ data.LuasAreaParkir }}</td></tr>
            <tr><td>LUAS AREA SALES</td><td>:</td><td>{{ data.LuasAreaSales }}</td></tr>
            <tr><td>LUAS GUDANG</td><td>:</td><td>{{ data.LuasGudang }}</td></tr>
            <tr><td>LUAS BANGUNAN</td><td>:</td><td>{{ data.LuasBangunan }}</td></tr>
            <tr><td>LUAS AREA TERBUKA</td><td>:</td><td>{{ data.LuasAreaTerbuka }}</td></tr>
            <tr><td>LUAS TERBANGUN</td><td>:</td><td>{{ data.LuasTerbangun }}</td></tr>
            <tr><td>TANGGAL PENGAJUAN</td><td>:</td><td>{{ tanggal_pengajuan }}</td></tr>
        </table>
    </div>

    {% for group in grouped_items_list %}
    <div>
        <p class="category-header">{{ loop.index }}. {{ group.category }}</p>
        <table class="price-table">
            <thead>
                <tr>
                    <th rowspan="2" style="width:3%;">NO.</th>
                    <th rowspan="2" class="text-left" style="width:34%;">JENIS PEKERJAAN</th>
                    <th rowspan="2" style="width:5%;">SATUAN</th>
                    <th rowspan="2" style="width:6%;">VOLUME</th>
                    <th colspan="2">HARGA SATUAN (Rp)</th>
                    <th colspan="2">TOTAL HARGA (Rp)</th>
                    <th rowspan="2" style="width:12%;">TOTAL HARGA (Rp)</th>
                </tr>
                <tr>
                    <th style="width:10%;">Material</th>
                    <th style="width:10%;">Upah</th>
                    <th style="width:10%;">Material</th>
                    <th style="width:10%;">Upah</th>
                </tr>
            </thead>
            <tbody>
                {% for item in group.items %}
                <tr>
                    <td>{{ loop.index }}</td>
                    <td class="text-left">{{ item.jenisPekerjaan }}</td>
                    <td>{{ item.satuan }}</td>
                    <td class="text-right">{{ item.volume }}</td>
                    <td class="text-right">{{ item.hargaMaterialFormatted }}</td>
                    <td class="text-right">{{ item.hargaUpahFormatted }}</td>
                    <td class="text-right">{{ item.totalMaterialFormatted }}</td>
                    <td class="text-right">{{ item.totalUpahFormatted }}</td>
                    <td class="text-right"><strong>{{ item.totalHargaFormatted }}</strong></td>
                </tr>
                {% endfor %}
                <tr class="sub-total-row">
                    <td colspan="6" class="text-right"><strong>SUB TOTAL</strong></td>
                    <td class="text-right">{{ group.subTotalMaterialFormatted }}</td>
                    <td class="text-right">{{ group.subTotalUpahFormatted }}</td>
                    <td class="text-right">{{ group.subTotalHargaFormatted }}</td>
                </tr>
            </tbody>
        </table>
    </div>
    {% endfor %}

    <table class="grand-total-table">
        <tbody>
            <tr><td>TOTAL (Rp)</td><td class="total-amount-cell">{{ grand_total }}</td></tr>
            <tr><td>PEMBULATAN (Rp)</td><td class="total-amount-cell">{{ pembulatan }}</td></tr>
            <tr><td>PPN 11% (Rp)</td><td class="total-amount-cell">{{ ppn }}</td></tr>
            <tr><td>GRAND TOTAL (Rp)</td><td class="total-amount-cell">{{ final_grand_total }}</td></tr>
        </tbody>
    </table>
    <div style="clear:both;"></div>

    <div class="signatures{% if is_batam_branch %} batam-two-cols{% endif %}">
        <div class="signature-box">
            <p>Dibuat</p>
            <div class="signature-content">
                {{ creator_details | safe }}
                <div class="signature-line"></div>
            </div>
            <p>KONTRAKTOR</p>
        </div>
        <div class="signature-box">
            <p>{% if is_batam_branch %}Menyetujui{% else %}Mengetahui{% endif %}</p>
            <div class="signature-content">
                {{ coordinator_approval_details | safe }}
                <div class="signature-line"></div>
            </div>
            <p>BRANCH BUILDING COORDINATOR</p>
        </div>
        {% if not is_batam_branch %}
        <div class="signature-box">
            <p>Menyetujui</p>
            <div class="signature-content">
                {{ manager_approval_details | safe }}
                <div class="signature-line"></div>
            </div>
            <p>BRANCH BUILDING &amp; MAINTENANCE MANAGER</p>
        </div>
        {% endif %}
    </div>
</body>
</html>
