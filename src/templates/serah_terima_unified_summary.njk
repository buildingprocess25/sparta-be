<!doctype html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <style>
    @page { size: A4; margin: 15mm; }
    body { font-family: Arial, sans-serif; font-size: 11px; color: #1f2937; margin: 0; }
    .cover-title { margin-top: 30px; border: 2px solid #ea580c; border-radius: 8px; padding: 22px; }
    .eyebrow { color: #ea580c; font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 1.6px; }
    h1 { margin: 8px 0 8px; font-size: 24px; color: #111827; }
    .subtitle { color: #475569; font-size: 12px; line-height: 1.5; }
    
    .score-container { margin-top: 40px; text-align: center; background: #fff7ed; border: 2px dashed #fdba74; border-radius: 12px; padding: 40px; }
    .score-label { color: #c2410c; font-size: 16px; font-weight: 800; text-transform: uppercase; letter-spacing: 2px; }
    .score-value { margin-top: 10px; font-size: 64px; font-weight: 900; color: #9a3412; }
    .score-max { font-size: 24px; color: #fb923c; font-weight: bold; }
    
    table { width: 100%; border-collapse: collapse; margin-top: 40px; }
    th, td { border: 1px solid #cbd5e1; padding: 12px; }
    th { background: #eef6ff; font-weight: 800; text-align: left; }
    .center { text-align: center; }
    .num { text-align: right; }
    .scope-name { font-weight: 800; color: #ea580c; }
    {{ sparta_pdf_css() | safe }}
  </style>
</head>
<body>
  {{ sparta_header("Rangkuman Penilaian Kualitas", nomor_ulok ~ " - " ~ (nama_toko or '-')) | safe }}
  
  <div class="cover-title">
    <div class="eyebrow">Nilai Toko (Quality Score)</div>
    <h1>Penilaian Kualitas Gabungan ({{ nomor_ulok }})</h1>
    <div class="subtitle">Halaman ini menampilkan rangkuman Nilai Toko dari seluruh lingkup pekerjaan yang telah diserahterimakan pada tanggal {{ created_at_formatted }}. Nilai rata-rata di bawah ini merepresentasikan kualitas pekerjaan secara menyeluruh.</div>
  </div>
  
  <div class="score-container">
    <div class="score-label">Nilai Toko Rata-Rata</div>
    <div class="score-value">{{ average_nilai_toko_formatted }}<span class="score-max"> / 100</span></div>
  </div>

  <table>
    <thead>
      <tr>
        <th style="width: 40px;" class="center">No</th>
        <th>Lingkup Pekerjaan</th>
        <th class="center">Nilai Toko</th>
      </tr>
    </thead>
    <tbody>
      {% for scope in scopes %}
      <tr>
        <td class="center">{{ loop.index }}</td>
        <td class="scope-name">{{ scope.lingkup_pekerjaan or '-' }}</td>
        <td class="center" style="font-size: 16px; font-weight: bold; color: #111827;">{{ scope.nilai_toko_formatted }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</body>
</html>
