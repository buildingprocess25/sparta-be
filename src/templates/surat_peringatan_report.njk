<!doctype html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <style>
    @page {
      size: A4;
      margin: 14mm 14mm;
    }

    body {
      font-family: Arial, sans-serif;
      font-size: 11px;
      color: #1f2937;
      margin: 0;
      position: relative;
    }

    .watermark {
      position: fixed;
      top: 50%;
      left: 50%;
      width: 240px;
      transform: translate(-50%, -50%);
      opacity: 0.08;
      z-index: 0;
      pointer-events: none;
    }

    .content {
      position: relative;
      z-index: 1;
    }

    .meta {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 10px;
    }

    .meta td {
      border: 1px solid #c7cbd1;
      padding: 5px 8px;
      vertical-align: top;
    }

    .meta .label {
      width: 160px;
      font-weight: 600;
      background: #f6f8fb;
    }

    .section-title {
      font-size: 12px;
      font-weight: 700;
      margin: 10px 0 5px;
      color: #e30613;
      text-transform: uppercase;
      border-bottom: 1px solid #e30613;
      padding-bottom: 3px;
    }
    
    .body-text {
      font-size: 11px;
      text-align: justify;
      margin: 0 0 6px;
      line-height: 1.5;
    }

    .poin-list {
      margin: 4px 0 8px 18px;
      padding: 0;
      font-size: 11px;
      line-height: 1.8;
    }
    .poin-list li {
      margin-bottom: 2px;
    }

    .catatan-box {
      margin: 5px 0 8px 0;
      font-size: 11px;
      line-height: 1.65;
      border: 1px solid #c7cbd1;
      padding: 6px 8px;
      background: #f8fafc;
      border-radius: 4px;
    }

    .hormat-kami {
      margin: 10px 0 0 0;
      font-size: 11px;
      line-height: 1.7;
    }

    .signatures {
      margin-top: 14px;
      width: 100%;
      page-break-inside: avoid;
    }

    .signatures table {
      width: 100%;
      border-collapse: separate;
      text-align: center;
      table-layout: fixed;
    }

    .signatures td {
      padding: 2px 4px;
      vertical-align: top;
    }

    .signature-space {
      height: 40px;
      min-height: 40px;
    }

    .sig-name {
      font-weight: 700;
      font-size: 11px;
    }

    .sig-role {
      font-size: 10px;
      color: #4b5563;
      margin-top: 2px;
    }

    .sig-timestamp {
      font-size: 10px;
      color: #555;
      font-style: italic;
      height: 18px;
      vertical-align: middle;
    }

    .footer {
      margin-top: 12px;
      font-size: 10px;
      color: #6b7280;
      text-align: right;
    }
    
    {{ sparta_pdf_css() | safe }}
  </style>
</head>
<body>
  {% if logoImageBase64 %}
  <img src="{{ logoImageBase64 }}" class="watermark" alt="watermark" />
  {% endif %}

  <div class="content">
  {{ sparta_header("Surat Peringatan " ~ spLevelRomawi, (nomorUlok and nomorUlok != '-') and (namaToko and namaToko != '-') and (nomorUlok ~ " - " ~ namaToko) or (namaKontraktor or "-")) | safe }}

  <div class="section-title">Informasi Proyek</div>
  <table class="meta">
    <tr>
      <td class="label">Nomor Surat</td>
      <td>{{ nomorSurat or '-' }}</td>
      <td class="label">Tanggal Surat</td>
      <td>{{ tanggalSurat }}</td>
    </tr>
    <tr>
      <td class="label">Nama Kontraktor</td>
      <td>{{ namaKontraktor or '-' }}</td>
      <td class="label">Cabang</td>
      <td>{{ targetCabang or '-' }}</td>
    </tr>
    {% if nomorUlok and nomorUlok != '-' %}
    <tr>
      <td class="label">Nomor ULOK</td>
      <td>{{ nomorUlok }}</td>
      <td class="label">Nama Toko</td>
      <td>{{ namaToko or '-' }}</td>
    </tr>
    {% endif %}
    {% if nomorSpk %}
    <tr>
      <td class="label">Nomor SPK</td>
      <td>{{ nomorSpk }}</td>
      {% if lingkupPekerjaan and lingkupPekerjaan != '-' %}
      <td class="label">Lingkup Pekerjaan</td>
      <td>{{ lingkupPekerjaan }}</td>
      {% else %}
      <td></td><td></td>
      {% endif %}
    </tr>
    {% elif lingkupPekerjaan and lingkupPekerjaan != '-' %}
    <tr>
      <td class="label">Lingkup Pekerjaan</td>
      <td colspan="3">{{ lingkupPekerjaan }}</td>
    </tr>
    {% endif %}
  </table>

  <div class="section-title">Isi Peringatan</div>

  {# ---- Paragraph pembuka berbeda-beda sesuai alasan SP ---- #}
  {% if alasan == 'KETERLAMBATAN' %}
  <p class="body-text">
    {% if nomorSpk %}Sehubungan dengan Surat Perintah Kerja No. {{ nomorSpk }}{% if lingkupPekerjaan and lingkupPekerjaan != '-' %} tentang pekerjaan {{ lingkupPekerjaan }}{% endif %}{% if nomorUlok and nomorUlok != '-' %} di Nomor ULOK {{ nomorUlok }}{% endif %}{% else %}Berdasarkan hasil evaluasi pelaksanaan pekerjaan{% if lingkupPekerjaan and lingkupPekerjaan != '-' %} {{ lingkupPekerjaan }}{% endif %}{% if nomorUlok and nomorUlok != '-' %} pada Nomor ULOK {{ nomorUlok }}{% endif %}{% endif %}, ternyata setelah dilakukan pengecekan masih ada beberapa pekerjaan yang mengalami <strong>keterlambatan penyelesaian</strong> yang tidak sesuai dengan jadwal yang telah disepakati, diantaranya sebagai berikut:
  </p>
  {% elif alasan == 'MENOLAK_SPK' %}
  <p class="body-text">
    {% if nomorSpk %}Sehubungan dengan Surat Perintah Kerja No. {{ nomorSpk }}{% if lingkupPekerjaan and lingkupPekerjaan != '-' %} tentang pekerjaan {{ lingkupPekerjaan }}{% endif %}{% if nomorUlok and nomorUlok != '-' %} di Nomor ULOK {{ nomorUlok }}{% endif %}, bahwa kontraktor tersebut di atas telah <strong>menolak atau tidak bersedia melaksanakan</strong> pekerjaan sesuai dengan SPK yang telah diterbitkan{% else %}Berdasarkan hasil evaluasi pelaksanaan pekerjaan{% if lingkupPekerjaan and lingkupPekerjaan != '-' %} {{ lingkupPekerjaan }}{% endif %}{% if nomorUlok and nomorUlok != '-' %} pada Nomor ULOK {{ nomorUlok }}{% endif %}, kontraktor tersebut di atas dinilai <strong>menolak atau tidak bersedia melaksanakan</strong> pekerjaan yang menjadi tanggung jawabnya{% endif %}, diantaranya sebagai berikut:
  </p>
  {% elif alasan == 'MANIPULASI' %}
  <p class="body-text">
    Berdasarkan hasil pemeriksaan dan temuan di lapangan{% if nomorUlok and nomorUlok != '-' %} pada lokasi {{ nomorUlok }}{% if namaToko and namaToko != '-' %} ({{ namaToko }}){% endif %}{% endif %}, kontraktor <strong>{{ namaKontraktor }}</strong> terbukti telah melakukan <strong>tindakan manipulasi dan/atau pelanggaran berat</strong> yang bertentangan dengan ketentuan yang berlaku, diantaranya sebagai berikut:
  </p>
  {% else %}
  <p class="body-text">
    Sehubungan dengan hasil evaluasi kinerja kontraktor <strong>{{ namaKontraktor }}</strong>{% if nomorUlok and nomorUlok != '-' %} pada lokasi {{ nomorUlok }}{% if namaToko and namaToko != '-' %} ({{ namaToko }}){% endif %}{% endif %}, ditemukan adanya hal-hal yang perlu mendapat perhatian serius dan tindak lanjut segera, diantaranya sebagai berikut:
  </p>
  {% endif %}

  <ol class="poin-list">
    <li><strong>{{ alasanSpText }}</strong></li>
    {% if catatanList %}
    {% for item in catatanList %}
    {% if item | trim %}
    <li>{{ item | trim }}</li>
    {% endif %}
    {% endfor %}
    {% endif %}
  </ol>

  {% if instruksiTindakLanjut %}
  <div class="section-title">Instruksi Tindak Lanjut</div>
  <div class="catatan-box">
    {{ instruksiTindakLanjut | replace("\n", "<br>") | safe }}
    {% if deadlineTindakLanjut and deadlineTindakLanjut != '-' %}
    <br><br><strong>Batas Waktu:</strong> {{ deadlineTindakLanjut }}
    {% endif %}
  </div>
  {% endif %}

  <p class="body-text">
    Kami menghimbau kepada Bapak/Ibu untuk menindaklanjuti perihal ketidaksesuaian diatas. Jika Bapak/Ibu tidak dapat memenuhi kewajiban tersebut, maka kami akan memberikan sanksi/denda sesuai dengan ketentuan yang sudah tertulis di dalam RKS.
  </p>

  <p class="body-text">
    Demikian Surat Peringatan {{ spLevelRomawi }} ini kami sampaikan. Atas perhatian dan kerjasamanya kami ucapkan terimakasih.
  </p>

  <p class="body-text hormat-kami">
    Hormat kami,<br>
    <strong>PT SUMBER ALFARIA TRIJAYA TBK</strong>
  </p>

  <div class="signatures">
    <table>
      <tr>
        <td>Dibuat oleh,</td>
        <td>Mengetahui,</td>
      </tr>
      <tr>
        <td class="sig-timestamp">
          {% if submittedAt %}{{ submittedAt | replace("T", " ") | truncate(16, true, "") }} WIB{% endif %}
        </td>
        <td class="sig-timestamp">
          {% if approvedAt %}{{ approvedAt | replace("T", " ") | truncate(16, true, "") }} WIB{% endif %}
        </td>
      </tr>
      <tr>
        <td><div class="signature-space"></div></td>
        <td><div class="signature-space"></div></td>
      </tr>
      <tr>
        <td class="sig-name">{{ submittedBy }}</td>
        <td class="sig-name">{{ approvedBy or "" }}</td>
      </tr>
      <tr>
        <td class="sig-role">Branch Building Coordinator/Support</td>
        <td class="sig-role">{% if approvedBy %}Branch Building &amp; Maintenance Manager{% endif %}</td>
      </tr>
    </table>
  </div>

  <div class="footer">
    Dokumen ini di-generate otomatis oleh sistem SPARTA Building pada {{ tanggalSurat }}
  </div>
  </div>
</body>
</html>
