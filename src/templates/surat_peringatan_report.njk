<!doctype html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <style>
    @page {
      size: A4;
      margin: 18mm 14mm;
    }

    body {
      font-family: Arial, sans-serif;
      font-size: 11px;
      color: #1f2937;
      margin: 0;
      position: relative;
    }

    .watermark {
      position: fixed;
      top: 50%;
      left: 50%;
      width: 240px;
      transform: translate(-50%, -50%);
      opacity: 0.08;
      z-index: 0;
      pointer-events: none;
    }

    .content {
      position: relative;
      z-index: 1;
    }

    .meta {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 14px;
    }

    .meta td {
      border: 1px solid #c7cbd1;
      padding: 6px 8px;
      vertical-align: top;
    }

    .meta .label {
      width: 170px;
      font-weight: 600;
      background: #f6f8fb;
    }

    .section-title {
      font-size: 13px;
      font-weight: 700;
      margin: 14px 0 6px;
      color: #e30613;
      text-transform: uppercase;
      border-bottom: 1px solid #e30613;
      padding-bottom: 4px;
    }
    
    .body-text {
      font-size: 11px;
      text-align: justify;
      margin: 0 0 10px;
      line-height: 1.7;
    }

    .poin-list {
      margin: 4px 0 12px 22px;
      padding: 0;
      font-size: 11px;
      line-height: 1.9;
    }
    .poin-list li {
      margin-bottom: 2px;
    }

    .catatan-box {
      margin: 6px 0 12px 0;
      font-size: 11px;
      line-height: 1.7;
      border: 1px solid #c7cbd1;
      padding: 8px;
      background: #f8fafc;
      border-radius: 4px;
    }

    .ttd-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 14px;
      page-break-inside: avoid;
    }

    .ttd-table td {
      border: 1px solid #c7cbd1;
      padding: 0;
      vertical-align: top;
      width: 50%;
      text-align: center;
    }
    
    .ttd-header {
      background: #f6f8fb;
      font-weight: 600;
      border-bottom: 1px solid #c7cbd1;
      padding: 6px;
    }

    .ttd-space {
      height: 60px;
    }

    .ttd-footer {
      padding: 6px;
    }

    .ttd-name {
      font-weight: bold;
      font-size: 11px;
    }

    .ttd-role {
      font-size: 10px;
      color: #4b5563;
      margin-top: 2px;
    }

    .footer {
      margin-top: 16px;
      font-size: 10px;
      color: #6b7280;
      text-align: right;
    }
    
    {{ sparta_pdf_css() | safe }}
  </style>
</head>
<body>
  {% if logoImageBase64 %}
  <img src="{{ logoImageBase64 }}" class="watermark" alt="watermark" />
  {% endif %}

  <div class="content">
  {{ sparta_header("Surat Peringatan " ~ spLevelRomawi, (nomorUlok or "-") ~ " - " ~ (namaToko or "-")) | safe }}

  <div class="section-title">Informasi Proyek</div>
  <table class="meta">
    <tr>
      <td class="label">Nomor Surat</td>
      <td>{{ nomorSurat or '-' }}</td>
      <td class="label">Tanggal Surat</td>
      <td>{{ tanggalSurat }}</td>
    </tr>
    <tr>
      <td class="label">Nama Kontraktor</td>
      <td>{{ namaKontraktor or '-' }}</td>
      <td class="label">Cabang</td>
      <td>{{ targetCabang or '-' }}</td>
    </tr>
    <tr>
      <td class="label">Nomor ULOK</td>
      <td>{{ nomorUlok or '-' }}</td>
      <td class="label">Nama Toko</td>
      <td>{{ namaToko or '-' }}</td>
    </tr>
    <tr>
      <td class="label">Nomor SPK</td>
      <td>{{ nomorSpk or '-' }}</td>
      <td class="label">Lingkup Pekerjaan</td>
      <td>{{ lingkupPekerjaan or '-' }}</td>
    </tr>
  </table>

  <div class="section-title">Isi Peringatan</div>
  <p class="body-text">
    Sehubungan dengan Surat Perintah Kerja No. {{ nomorSpk or '-' }} tentang pekerjaan {{ lingkupPekerjaan or '-' }} di {{ nomorUlok or '-' }}, ternyata setelah dilakukan pengecekan masih ada beberapa pekerjaan yang tidak sesuai dengan ketentuan yang ada di RKS, diantaranya sebagai berikut:
  </p>

  <ol class="poin-list">
    <li><strong>{{ alasanSpText }}</strong></li>
    {% if catatan and catatan != "-" %}
    {% set lines = catatan.split("\n") %}
    {% for line in lines %}
    {% if line | trim %}
    <li>{{ line | trim }}</li>
    {% endif %}
    {% endfor %}
    {% endif %}
  </ol>

  {% if instruksiTindakLanjut %}
  <div class="section-title">Instruksi Tindak Lanjut</div>
  <div class="catatan-box">
    {{ instruksiTindakLanjut | replace("\n", "<br>") | safe }}
    {% if deadlineTindakLanjut and deadlineTindakLanjut != "-" %}
    <br><br><strong>Batas Waktu:</strong> {{ deadlineTindakLanjut }}
    {% endif %}
  </div>
  {% endif %}

  <p class="body-text">
    Kami menghimbau kepada Bapak/Ibu untuk menindaklanjuti perihal ketidaksesuaian diatas. Jika Bapak/Ibu tidak dapat memenuhi kewajiban tersebut, maka kami akan memberikan sanksi/denda sesuai dengan ketentuan yang sudah tertulis di dalam RKS.
  </p>

  <p class="body-text">
    Demikian Surat Peringatan {{ spLevelRomawi }} ini kami sampaikan. Atas perhatian dan kerjasamanya kami ucapkan terimakasih.
  </p>

  <div class="section-title">Pengesahan</div>
  <table class="ttd-table">
    <tr>
      <td>
        <div class="ttd-header">Dibuat oleh,</div>
        <div class="ttd-space"></div>
        <div class="ttd-footer">
          <div class="ttd-name">{{ submittedBy }}</div>
          <div class="ttd-role">Branch Building Coordinator/Support</div>
        </div>
      </td>
      <td>
        <div class="ttd-header">Mengetahui,</div>
        <div class="ttd-space"></div>
        <div class="ttd-footer">
          <div class="ttd-name">{{ approvedBy }}</div>
          <div class="ttd-role">Branch Building &amp; Maintenance Manager</div>
        </div>
      </td>
    </tr>
  </table>

  <div class="footer">
    Dokumen ini di-generate otomatis oleh sistem SPARTA Building pada {{ tanggalSurat }}
  </div>
  </div>
</body>
</html>
