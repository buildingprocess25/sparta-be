<!doctype html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Notifikasi Persetujuan SPK</title>
</head>
<body style="margin:0; padding:0; font-family: Arial, Helvetica, sans-serif; background:#f5f5f5;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#f5f5f5; padding:24px;">
        <tr>
            <td align="center">
                <table role="presentation" width="600" cellspacing="0" cellpadding="0" style="background:#ffffff; border-radius:8px; overflow:hidden;">
                    <tr>
                        <td style="padding:24px;">
                            <h2 style="margin:0 0 12px; font-size:20px; color:#1b1b1b;">Notifikasi Approval SPK</h2>
                            <p style="margin:0 0 12px; font-size:14px; color:#333333;">
                                {{ greeting }}.
                            </p>
                            <p style="margin:0 0 12px; font-size:14px; color:#333333;">
                                Yth Bapak/Ibu {{ nama_lengkap }} Branch Manager {{ cabang }}.
                            </p>
                            <p style="margin:0 0 12px; font-size:14px; color:#333333;">
                                Terdapat pengajuan SPK yang memerlukan persetujuan untuk cabang {{ cabang }}. Mohon meninjau melalui aplikasi Sparta Building.
                            </p>
                            <p style="margin:0 0 12px; font-size:14px; color:#333333; font-weight:600;">
                                Alur persetujuan:
                            </p>
                            <ol style="margin:0 0 12px 18px; padding:0; font-size:14px; color:#333333;">
                                <li>Login ke aplikasi Sparta Building.</li>
                                <li>Masukkan email SAT dan password.</li>
                                <li>Pilih menu Approval pada sidebar dan pilih SPK terkait.</li>
                            </ol>
                            <p style="margin:0 0 12px; font-size:14px; color:#333333;">
                                Dapat diakses pada link berikut: <a href="https://sparta-building.vercel.app/">https://sparta-building.vercel.app/</a>
                            </p>
                            <p style="margin:0 0 12px; font-size:14px; color:#333333;">
                                Terima Kasih.
                            </p>
                        
                            <p style="margin:0; font-size:12px; color:#666666;">
                                Dikirim pada: {{ sent_at }} WIB
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
